#!/usr/bin/bash
# Automatically configure Windows Boot Manager in GRUB on BlossomOS
set -euo pipefail

CUSTOM_CFG="/boot/grub2/custom.cfg"

# Ensure we have access to /boot/grub2
if [ ! -d "/boot/grub2" ]; then
    echo "/boot/grub2 directory not found. Skipping dual boot detection."
    exit 0
fi

# We will search for the Windows bootloader partition.
windows_uuid=""

# Check currently mounted ESPs first
# Usually, /boot/efi is mounted. Let's see if Microsoft/Boot/bootmgfw.efi exists there.
if [ -f "/boot/efi/EFI/Microsoft/Boot/bootmgfw.efi" ] || \
   [ -f "/boot/efi/efi/Microsoft/Boot/bootmgfw.efi" ] || \
   [ -f "/boot/efi/EFI/microsoft/boot/bootmgfw.efi" ] || \
   [ -f "/boot/efi/efi/microsoft/boot/bootmgfw.efi" ]; then
    # Get the UUID of the device mounted at /boot/efi
    windows_uuid=$(findmnt -rn -o UUID -M /boot/efi || true)
fi

# If not found at /boot/efi, let's scan all other vfat/fat partitions
if [ -z "$windows_uuid" ]; then
    # List all block devices that are partitions and have vfat/msdos filesystem
    # We ignore the currently mounted /boot/efi to avoid double-checking
    efi_mount=$(findmnt -rn -o SOURCE -M /boot/efi || true)
    
    # Run lsblk to get candidate devices
    devices=$(lsblk -rn -o NAME,FSTYPE,UUID || true)
    
    while read -r name fstype uuid; do
        [ -z "$name" ] && continue
        [ "$fstype" != "vfat" ] && [ "$fstype" != "msdos" ] && continue
        devpath="/dev/$name"
        
        # Skip the one already mounted at /boot/efi
        if [ -n "$efi_mount" ]; then
            if [ "$devpath" = "$efi_mount" ] || [ "$(readlink -f "$devpath" 2>/dev/null)" = "$(readlink -f "$efi_mount" 2>/dev/null)" ]; then
                continue
            fi
        fi
        
        # Mount read-only to check
        mntdir=$(mktemp -d /tmp/win-esp-XXXXXX)
        if mount -o ro "$devpath" "$mntdir" 2>/dev/null; then
            # Search case-insensitively for the file
            if [ -f "$mntdir/EFI/Microsoft/Boot/bootmgfw.efi" ] || \
               [ -f "$mntdir/efi/Microsoft/Boot/bootmgfw.efi" ] || \
               [ -f "$mntdir/EFI/microsoft/boot/bootmgfw.efi" ] || \
               [ -f "$mntdir/efi/microsoft/boot/bootmgfw.efi" ] || \
               find "$mntdir" -maxdepth 4 -ipath "*/efi/microsoft/boot/bootmgfw.efi" -print -quit 2>/dev/null | grep -q .; then
                windows_uuid="$uuid"
                umount "$mntdir"
                rmdir "$mntdir"
                break
            fi
            umount "$mntdir"
        fi
        rmdir "$mntdir"
    done <<< "$devices"
fi

if [ -n "$windows_uuid" ]; then
    echo "Found Windows Boot Manager on EFI partition with UUID: $windows_uuid"
    
    # Generate the custom.cfg contents
    # We use a temporary file and atomically move it to avoid corruption
    tmp_cfg=$(mktemp /boot/grub2/custom.cfg.XXXXXX)
    
    cat << EOF > "$tmp_cfg"
# Automatically generated by blossomos-dualboot-detect.service
set timeout_style=menu
set timeout=6

menuentry 'Windows Boot Manager' {
    insmod part_gpt
    insmod fat
    search --no-floppy --fs-uuid --set=root $windows_uuid
    chainloader /EFI/Microsoft/Boot/bootmgfw.efi
}
EOF
    
    mv "$tmp_cfg" "$CUSTOM_CFG"
    chmod 644 "$CUSTOM_CFG"
    echo "Successfully updated $CUSTOM_CFG"
else
    echo "Windows Boot Manager not detected."
    # If custom.cfg was automatically generated by us previously and Windows is no longer there, remove it
    if [ -f "$CUSTOM_CFG" ] && grep -q "Automatically generated by blossomos-dualboot-detect.service" "$CUSTOM_CFG"; then
        echo "Removing outdated Windows entry from $CUSTOM_CFG"
        rm -f "$CUSTOM_CFG"
    fi
fi
