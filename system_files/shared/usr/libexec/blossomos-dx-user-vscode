#!/usr/bin/bash
# Set up VSCode for BlossomOS DX users
set -euo pipefail

# Ensure VSCode settings directory exists
mkdir -p "${HOME}/.config/Code/User"

# Set default VSCode settings if not already present
SETTINGS="${HOME}/.config/Code/User/settings.json"
if [[ ! -f "${SETTINGS}" ]]; then
    cat > "${SETTINGS}" <<'EOF'
{
    "telemetry.telemetryLevel": "off",
    "update.mode": "none"
}
EOF
fi
